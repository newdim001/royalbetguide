      {/* CTA */}
      {casino.affiliateUrl && (
      <div className="mt-10 rounded-2xl bg-gradient-to-br from-corg-500 to-corg-600 p-8 text-center">
        <h3 className="text-xl font-bold text-white">Ready to Play at {casino.name}?</h3>
