<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
<meta content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=3.0, user-scalable=yes" name="viewport">
<meta name="robots" content="noindex,nofollow">
  
<title>betmgm.com</title>
<style>

body, div, dl, dt, dd, ul, ol, li, h1, h2, h3, h4, h5, h6, pre, form, fieldset, input, textarea, p, blockquote, th, td {margin:0; padding:0;box-sizing:border-box;}

/*
Style definition
================
*/

body {
    color:#cccccc;
    background:#0F0F0F;
    font: 13px/1.6 Verdana, Arial, Helvetica, sans-serif;
    font:13px/1.6 Verdana, Arial, Helvetica, sans-serif;
    position:relative;
    -webkit-text-size-adjust:none;
    -ms-text-size-adjust:none;
    text-size-adjust:none;
}
.container {
    margin:0 auto;
    width: 100%;
	max-width:800px;
}

header {
	background-color:#000000;
	color:#FFCC00;;
	padding-top:20px;
	padding-bottom:10px;
}

.logo {padding:0 10px;}

.logo > img {max-height:45px; width:auto;}


/*
TYPOGRAPHY
==========
*/
h3 { font-weight: bold;	line-height: 1.2;}
p { font-size: 1em; }

/*
Navigation/language Switcher
==========
*/
nav {background-color: #272727;}
nav ul li {display:inline-block; list-style-type:none; padding:5px; border-bottom:2px #272727 solid;}
nav ul li:hover {display:inline-block; list-style-type:none; border-bottom:2px #FFFFFF solid;}
nav ul li a {text-decoration:none; color:#FFFFFF; font-size:11px;}

/*
Maincontentarea
==========
*/
main {background-color: #0F0F0F;}
main .container{background-color:#1e1e1e; padding:5px 0 5px 0;}
main .container .block{ padding:5px 10px 5px 10px;}
main .container .block .copy-header{ padding:10px; background-color:#000000; color:#ffffff; }
main .container .block .copy-text{ padding:10px; background-color:#0F0F0F;  color:#FFFFFF;}

footer .copyright {font-size:11px; text-align:center; padding-top:20px; color: #fff;}
footer a{color:#cccccc;text-decoration:underline;}
    
.ep div.block > div > h1:before { content:'Something went wrong: ';}
.ep div.block > div.cf-im-under-attack > div > h1,
.ep div.block > h1,
.ep div.block > div > h1 { padding: 10px; color:#ffffff; font-size:16px;}
.ep div.block > div.cf-im-under-attack > div > h2,
.ep div.block > div > h2 { padding: 10px; font-size:15px;}
.ep div.block > div.cf-im-under-attack > div > h3,
.ep div.block > div > h3 { padding: 10px; font-size:14px;}
    
.ep div.block > div.cf-im-under-attack > div > p,
.ep div.block > div > p { padding: 10px;}
    
.ep div.block > div.cf-im-under-attack > div > ul,
.ep div.block > div > ul { padding: 10px; list-style-position:inside;}
    
.ep div.block > div.cf-im-under-attack > div > a.cf_reload_button,
.ep div.block > div > a.cf_reload_button { margin:10px 10px 20px 10px; display:inline-block; background-color:#ffffff; border-radius:3px; padding:10px 20px; color:#000000; text-decoration:none; }


footer svg{max-width:32px;}
path.st0{fill:#d5d5d5}

@media only screen and (max-width: 1024px) {
    .logo {text-align:center;}
}

.de, .es, .it, .sv, .tr, .bg, .fr, .el, .pl, .da, .cs, .hu, .nl, .pt, .ru, .sl, .hr, .sk, .ro, .fi, .ca, .nb, .pt-br{
  display: none;
}
</style>

</head>
<body>
    <section>
        <header>
            <div class="container">
    <div class="logo">
        <img src="data:image/svg+xml;base64," alt="logo">
    </div>
</div>

        </header>
        <main>
            <div class="ep">
  <div class="container">
    <div class="block">
        <div>5.78.222.80</div>
        <div>a04bcff588fcb74e</div>
    </div>
  </div>
</div>

        </main>
        <footer>
            <div class="container copyright">
    <p><span class="copyright-text">&copy; <script>document.write(new Date().getFullYear())</script> BetMGM</span></p><br>
