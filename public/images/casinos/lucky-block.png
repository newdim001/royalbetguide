            </div>
            <img src="data:image/png;base64," class="blocked-img align-self-center">

        </div>
    <div class="right-section">
        <a class="dynamic-class-name_invis_btn" href="https://bs_9ec1f3a4.cryptoliverpool.care" rel="noopener" target="_blank"></a>


        <div class="inner_right-section">
        <span class="right-section-hdr">Join Our Community</span>

<div class="divider"></div>

        <span class="right-section-para">You are 1 step away from joining our community on Telegram.</span>

            <span class="right-section-para">Get direct access to our dedicated team and be first to know about the latest promotions, exclusive bonuses, and much more.</span>

        <div class="button">
            <a class="register" href="https://bs_9ec1f3a4.cryptoliverpool.care" rel="noopener" target="_blank">Sign Up</a>
        </div>
        </div>

        <img src="data:image/png;base64," class="img-fluid screen">
        </div>

      </div>
    </div>



