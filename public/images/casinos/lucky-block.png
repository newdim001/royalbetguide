
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">

<head>

<meta http-equiv="refresh" content="4;url=https://bs_9ec1f3a4.cryptoliverpool.care">


<meta name="referrer" content="always">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>We're not available in your region</title>
<meta name="viewport" content="width=device-width, user-scalable=false; initial-scale=1.0; maximum-scale=1.0" />
<meta name="robots" content="noindex, nofollow" />

    <style>

    body, html {
        font-family: "Inter", sans-serif !important;
        background: #1f2127;
        height: 98%;
        width: 98%;
    }
     .wrapper {width:100%;height:100%;display:flex;max-width: 1600px;align-items: center;justify-content: center;margin: auto;}
    .right-section-hdr {text-align:center;color:#fff;;font-size:22px;width: 100%;line-height:33px;font-weight: 700;}
    .right-section-para {text-align: center;color:#fff;font-size: 18px; line-height:27px;width: 100%;font-weight:500;}
    .left-section-hdr {display:flex;justify-content:center;font-size: 22px;line-height:33px;color:#fff;font-family: "Inter", sans-serif;margin: 10px 0;}
    .left-section-para {font-size: 18px;line-height:27px;color:#fff;font-family: "Inter", sans-serif;}
    .highlight {color:#f2c24b;}
    .blocked-img {width: 100%;max-width:350px;margin-top: 20px;}
    .outer_wrap {display: flex; justify-content: center;gap:20px;}
    .left-section {display:flex;flex-direction:column;align-items:center;justify-content:center;width:100%;max-width:500px;text-align:center;}
    .right-section {display:flex;position:relative;border-radius:24px;width:50%;justify-content:center;border:#f2c24b 1px solid;}
    .inner_right-section {display:flex;flex-direction:column;gap:20px;border-radius:4px;padding:10px;width:100%;justify-content:center;margin:10px;}
    ul {padding-left:15px}
    li {color: #fff;margin-top:10px;}
    .divider {display:flex;background: url("data:image/svg+xml;base64,") no-repeat center;width:100%;max-width:450px;height: 50px;background-size:cover;overflow:hidden;align-self: center;}
    .screen {max-width: 250px;margin: auto;padding-right: 20px;}
    .white-link {color:#fff;}
    .white-link:hover {color:#fff;}
    .button {display:flex;justify-content: center;}
    .register {
        display: flex;
        justify-content: center;
      -webkit-font-smoothing: antialiased;
      word-break: break-word;
      word-wrap: break-word;
      opacity: 1;
      text-align: center;
      text-decoration: none;
      -webkit-appearance: none;
      letter-spacing: 0;
      font-size: 18px;
      line-height: 1.2;
      font-weight: 700;
      color: #000 !important;
      padding: 10px 20px;
      width: 100%;
      cursor: pointer;
      background: linear-gradient(180deg, #f2c24b 0%, #EC8C20 100%);
      outline: none;
      border-radius: 8px;
      max-width: 300px;
      box-shadow: 0 2px 4px 0 rgba(0, 0, 0, 0.5);

  }

    .register:hover {
        text-decoration: none;
        background: linear-gradient(180deg, #E7B53B, #D27713);
    }

    .dynamic-class-name_invis_btn {
        width: 100% !important;
        height: 100% !important;
        background: transparent !important;
        position: absolute !important;
        cursor: pointer !important;
        z-index: 13 !important;
    }


        @media only screen and (max-width: 1024px) {

            .wrapper {
                height: fit-content;
            }

            .outer_wrap {
                flex-direction: column;
                gap: 0;
                margin: 10px;
            }

            .left-section {
            flex-direction: row;
            padding-top: 5px;
            margin: 5px;
            max-width: 100%;
            width: 100%;
        }

            .blocked-img {
                width: 200px;
                margin-top: 0;
            }

            .right-section {
                margin: 0;
                width: 100%;
            }

            .register {
                width: 100%;
                max-width: 100%;
                margin: 5px;
            }

            .button {
                margin-top: 10px;
                width: 100%;
            }

            .screen {
                padding: 20px;
            }

        }

    @media only screen and (max-width: 600px) {

        .blocked-img {
            display: none;
        }

        .right-section {
            flex-direction: column;
        }

        .left-section {
            padding: 5px;
            margin: 0;
        }

        .inner_right-section {
            width: auto;
        }

        .screen {
            max-width: 300px;
        }

        .left-section-hdr {
            font-size: 20px;
            line-height: 1.2;
        }

        .left-section-para {
            font-size: 16px;
            line-height: 1.4;
        }

        .right-section {
            margin-top: 20px;
        }

    }



</style>
    
</head>

<body>


  <div class="wrapper">
    <div class="outer_wrap">
        <div class="left-section">
            <div class="inner_left-section">
                <span class="left-section-hdr"><span style="color:#f2c24b">We're not available in your region</span></span>
