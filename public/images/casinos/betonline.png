/* Reset CSS */
html, body, div, span, applet, object, iframe, h1, h2, h3, h4, h5, h6, p, blockquote, button, pre, a, abbr, acronym, address, big, cite, code, del, dfn, em, img, ins, kbd, q, s, samp, small, strike, strong, sub, sup, tt, var, b, u, i, center, dl, dt, dd, ol, ul, li, fieldset, form, label, legend, table, caption, tbody, tfoot, thead, tr, th, td, article, aside, canvas, details, embed, figure, figcaption, footer, header, hgroup, menu, nav, output, ruby, section, summary, time, mark, audio, video { margin: 0; padding: 0; border: 0; font-size: 100%; font: inherit; vertical-align: baseline; outline:none; text-decoration:none; text-rendering: optimizeLegibility; -webkit-font-smoothing: antialiased; outline: none; }
article, aside, details, figcaption, figure, footer, header, hgroup, menu, nav, section { display: block; outline: none; }
body {line-height: 1.2;position: relative;font-family: "Open Sans", sans-serif;background: #252525;color: #fff;}
ol, ul { list-style: none; }

/* General */
.wrapper {width: 100%;max-width: 1920px;margin: 0 auto;position: relative;}
.container {width: 100%;box-sizing: border-box;padding: 0 3%;position: relative;}
img {max-width: 100%;height: auto;display: block;}

/* Header */
header {padding: 25px 0;text-align: center;font-size: 0;background: #2d2d2d;}
header .container { text-align: left; }
header .logo {width: 45%;max-width: 220px;display: inline-block;vertical-align: middle;padding-right: 2%;}
header .trusted {width: calc(45% - 10px);max-width: 160px;display: inline-block;vertical-align: middle;}

/* Body */
.info {text-align: center;width: 92%;max-width: 750px;margin: 51px auto 50px auto;border-radius: 25px;box-sizing: border-box;}
.info .top {background: no-repeat transparent url(data:image/jpeg;base64,) center center;background-size: cover;border-top-left-radius: 30px;border-top-right-radius: 30px;padding-top: 25px;padding-bottom: 25px;}

.top h1 {font-size: 27px;font-weight: 600;margin-bottom: 35px;}
.top h1:before {content: "";width: 110px;height: 2px;background: #fff;display: block;margin: 0 auto 25px auto;}
.top .warning {width: 10%;margin-bottom: 25px;max-width: 37px;display: inline-block;}
.top p {font-size: 20px;padding-bottom: 23PX;display: block;font-weight: 200;letter-spacing: 1px;line-height: 1.3;width: 100%;max-width: 500px;margin: 0 auto 30px auto;}
.top .cloudflareinfo { text-align: center; max-width: initial; }
.top .cloudflareinfo p {margin: 0;max-width: initial;font-size: 14px;letter-spacing: inherit;padding-bottom: 10px;}

.info .bottom {background: #ededed;border-bottom-right-radius: 30px;border-bottom-left-radius: 30px;padding-top: 40px;padding-bottom: 40px;}
.bottom .btn {width: 90%;max-width: 400px;border-radius: 5px;background: #fff;color: #ee3536;display: block;margin: 0 auto 41px auto;padding: 17px 0;font-weight: 600;font-size: 19px;-webkit-box-shadow: 0px 1px 6px 2px rgb(0 0 0 / 10%);box-shadow: 0px 1px 6px 2px rgb(0 0 0 / 10%);}
.bottom .livechat { background: #fff no-repeat url(data:image/svg+xml;base64,); background-position: 4% center; background-size: 37px; position: relative;}
.bottom .livechat:before { content: 'For Quick Response'; background: #76c405; color: #fff; font-size: 12px; padding: 4px 13px; display: block; position: absolute; top: -13px; right: -13px; border-radius: 4px; font-weight: 100; }
.bottom .helpcenter {background: #fff no-repeat url(data:image/svg+xml;base64,);background-position: 5% center;background-size: 24px;}
.bottom .icons { width: 90%; max-width: 400px; margin: 0 auto; display: flex; justify-content: space-between;}
.bottom .icons img { height: 26px; }

/* Footer */
footer {display: block;text-align: center;}
footer p {font-weight: 400;font-size: 20px;padding: 50px;}

/* Responsive */
@media only screen and (max-width: 800px) {
	body { min-width: 320px; }
	.info p {font-size: 16px;letter-spacing: 0.5px;}
	.info br { display: none; }
	#chatliveimg {/* padding-top: 50px; */}
	footer p { font-size: 14px; }
}

@media only screen and (max-width: 550px) {
	.info { margin: 25px auto 25px auto;}
	.top h1 { font-size: 25px; }
	.top p {margin-bottom: 27px;}
	.top .cloudflareinfo p { font-size: 14px; }
	.bottom .icons img {height: 19px;}
}


</style>
	</head>
	<body>
		<script type="text/javascript">
