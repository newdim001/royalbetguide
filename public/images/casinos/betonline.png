		</section>
<script>
fetch('https://betonline.ag/cdn-cgi/trace')
  .then(res => res.text())
  .then(data => {
const lines = data.split('\n');
const ipLine = lines.find(line => line.startsWith('ip='));
const ip = ipLine?.split('=')[1];
if (ip) {
  document.getElementById('ip').textContent = ip;
} else

{   document.getElementById('ip').textContent = 'Not Detected'; }   }
)
  .catch(() =>

{ document.getElementById('ip').textContent = 'Error Obtaining IP';   }
);
</script>
