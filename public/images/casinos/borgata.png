<style>blockquote,body,dd,div,dl,dt,fieldset,form,h1,h2,h3,h4,h5,h6,input,li,ol,p,pre,td,textarea,th,ul{box-sizing:border-box;margin:0;padding:0}body{-webkit-text-size-adjust:none;-ms-text-size-adjust:none;text-size-adjust:none;background:#fff;color:#3c3d41;font:13px/1.6 Verdana,Arial,Helvetica,sans-serif;position:relative}.container{margin:0 auto;max-width:800px;width:100%}header{background-color:#000;color:#fff;padding-bottom:10px;padding-top:20px}.logo{padding:0 10px}.logo>img{max-height:41px;width:auto}h3{font-weight:700;line-height:1.2}p{font-size:1em}nav{background-color:#fff}nav ul li{border-bottom:2px solid #fff;padding:5px}nav ul li,nav ul li:hover{display:inline-block;list-style-type:none}nav ul li:hover{border-bottom:2px solid #3c3d41}nav ul li a{color:#3c3d41;font-size:11px;text-decoration:none}main,main .container{background-color:#fff}main .container{padding:5px 0}main .container .block{padding:5px 10px}main .container .block .copy-header{background-color:#e5e5e5;color:#000;padding:10px}main .container .block .copy-text{background-color:#fff;color:#3c3d41;padding:10px}footer .copyright{color:#000;font-size:11px;padding-top:20px;text-align:center}footer a{color:#ccc;text-decoration:underline}.ep div.block>div>h1:before{content:"Something went wrong: "}.ep div.block>div.cf-im-under-attack>div>h1,.ep div.block>div>h1,.ep div.block>h1{color:#000;font-size:16px;padding:10px}.ep div.block>div.cf-im-under-attack>div>h2,.ep div.block>div>h2{font-size:15px;padding:10px}.ep div.block>div.cf-im-under-attack>div>h3,.ep div.block>div>h3{font-size:14px;padding:10px}.ep div.block>div.cf-im-under-attack>div>p,.ep div.block>div>p{padding:10px}.ep div.block>div.cf-im-under-attack>div>ul,.ep div.block>div>ul{list-style-position:inside;padding:10px}.ep div.block>div.cf-im-under-attack>div>a.cf_reload_button,.ep div.block>div>a.cf_reload_button{background-color:#000;border-radius:3px;color:#e5e5e5;display:inline-block;margin:10px 10px 20px;padding:10px 20px;text-decoration:none}footer svg{max-width:32px}path.st0{fill:#000}@media only screen and (max-width:1024px){.logo{text-align:center}}.bg,.ca,.cs,.da,.de,.el,.es,.fi,.fr,.hr,.hu,.it,.nb,.nl,.pl,.pt,.pt-br,.ro,.ru,.sk,.sl,.sv,.tr{display:none}</style>

